{
  "name": "html-voxels-to-bbmodel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.mjs",
  "scripts": {
    "convert": "node scripts/html-voxels-to-bbmodel.mjs",
    "dev": "node server.mjs",
    "desktop": "electron .",
    "dist:win": "node scripts/build-win-installer.mjs"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.voxelworkbench.desktop",
    "productName": "Voxel Workbench",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": false,
    "files": [
      "electron-main.mjs",
      "server.mjs",
      "web/**/*",
      "scripts/**/*",
      "ex/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Voxel-Workbench-${version}-win-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voxel Workbench",
      "artifactName": "Voxel-Workbench-${version}-win-${arch}-setup.${ext}"
    }
  }
}
